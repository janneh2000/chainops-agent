# ─── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── RPC Endpoint ──────────────────────────────────────────────────────────
# Free options: https://eth.llamarpc.com (public, rate-limited)
# Recommended: Alchemy (https://alchemy.com) or Infura (https://infura.io)
RPC_URL=https://eth.llamarpc.com

# ─── Slack Alerts (optional) ───────────────────────────────────────────────
# Create a webhook at https://api.slack.com/apps → Incoming Webhooks
# Leave empty to disable Slack alerts
SLACK_WEBHOOK_URL=

# ─── Scanner Settings ──────────────────────────────────────────────────────
# How often the background anomaly scanner runs (seconds)
SCAN_INTERVAL_SECONDS=60

# How often the Web3 exporter scrapes the RPC (seconds)
SCRAPE_INTERVAL=15
